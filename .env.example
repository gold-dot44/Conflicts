# Microsoft Entra ID (Azure AD)
AZURE_AD_CLIENT_ID=your-client-id
AZURE_AD_CLIENT_SECRET=your-client-secret
AZURE_AD_TENANT_ID=your-tenant-id

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-random-secret-here

# PostgreSQL (Azure Database for PostgreSQL Flexible Server)
DATABASE_URL=postgresql://user:password@your-server.postgres.database.azure.com:5432/conflicts?sslmode=require

# Clio API
CLIO_CLIENT_ID=your-clio-client-id
CLIO_CLIENT_SECRET=your-clio-client-secret
CLIO_REDIRECT_URI=http://localhost:3000/api/clio/callback
CLIO_API_BASE_URL=https://app.clio.com/api/v4

# Azure Blob Storage
AZURE_STORAGE_CONNECTION_STRING=your-storage-connection-string
AZURE_STORAGE_CONTAINER_AUDIT=audit-trails
AZURE_STORAGE_CONTAINER_IMPORTS=lateral-imports
